# ==========================================
# Variables de Producción - Coolify
# ==========================================
# MySQL se crea como servicio SEPARADO en Coolify
# Estas variables van en el docker-compose

# API Rust/Axum
SERVER_PORT=8000
DATABASE_URL=mysql://monitoreo:CHANGE_ME@<mysql-host>:3306/monitoreo_regional
RUST_LOG=info

# JWT Secret (generar con: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
