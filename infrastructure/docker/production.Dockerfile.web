# ==========================================
# SvelteKit Web - Producción
# ==========================================
# Multi-stage build para minimizar imagen final

# ==========================================
# ETAPA 1: Builder
# ==========================================
FROM node:22-alpine AS builder
WORKDIR /app

# Copiar package.json y lockfile
COPY apps/web/package.json apps/web/pnpm-lock.yaml ./

# Habilitar pnpm
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

# Instalar dependencias
RUN pnpm install

# Copiar resto del código
COPY apps/web/ ./

# Build de la aplicación
RUN pnpm build

# ==========================================
# ETAPA 2: Runtime (nginx para estático)
# ==========================================
FROM nginx:alpine AS runtime

# Crear estructura de directorios correcta
RUN mkdir -p /usr/share/nginx/html

# Copiar archivos estáticos compilados de SvelteKit
# adapter-auto genera los archivos en /build
COPY --from=builder /app/build /usr/share/nginx/html

# Copiar configuración de nginx
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
