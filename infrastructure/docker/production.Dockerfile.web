# ==========================================
# SvelteKit Web - Producción
# ==========================================
# Multi-stage build para minimizar imagen final

# ==========================================
# ETAPA 1: Builder
# ==========================================
FROM node:22-alpine AS builder
WORKDIR /app

# Instalar dependencias del proyecto
COPY apps/web/package.json apps/web/pnpm-lock.yaml* ./
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

# Copiar solo lo necesario para instalar deps
COPY apps/web/ ./

# Instalar dependencias
RUN pnpm install --frozen-lockfile

# Build de la aplicación
RUN pnpm build

# ==========================================
# ETAPA 2: Runtime (nginx para estático)
# ==========================================
FROM nginx:alpine AS runtime

# Copiar archivos estáticos compilados
COPY --from=builder /app/.svelte-kit/output /usr/share/nginx/html
# Copiar configuración de nginx
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
