# ==========================================
# SvelteKit Web - Producción
# ==========================================
# Multi-stage build para minimizar imagen final

# ==========================================
# ETAPA 1: Builder
# ==========================================
FROM node:22-alpine AS builder
WORKDIR /app

# Copiar package.json y lockfile
COPY apps/web/package.json apps/web/pnpm-lock.yaml ./

# Habilitar pnpm
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

# Copiar resto del código
COPY apps/web/ ./

# Build de la aplicación (se ejecuta en /app que ya tiene apps/web/)
RUN pnpm build

# ==========================================
# ETAPA 2: Runtime (nginx para estático)
# ==========================================
FROM nginx:alpine AS runtime

# Crear estructura de directorios correcta
RUN mkdir -p /usr/share/nginx/html

# Copiar archivos estáticos compilados de SvelteKit
# pnpm build genera los archivos en apps/web/build/
COPY --from=builder /app/apps/web/build /usr/share/nginx/html

# Copiar configuración de nginx
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
