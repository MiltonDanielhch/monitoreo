# ==========================================
# SvelteKit Web - Producción
# ==========================================
# Multi-stage build para minimizar imagen final

# ==========================================
# ETAPA 1: Builder
# ==========================================
FROM node:22-alpine AS builder
# 1. Nos paramos en la raíz del contenedor para mantener limpias las rutas
WORKDIR /app

# 2. Habilitamos pnpm de forma global
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

# 3. Copiamos los archivos de dependencias respetando la estructura original
COPY apps/web/package.json ./apps/web/
COPY apps/web/pnpm-lock.yaml ./apps/web/

# 4. Ahora sí, entramos a la carpeta del frontend e instalamos de forma segura
WORKDIR /app/apps/web
RUN pnpm install

# 5. Copiamos todo el resto del código del frontend
COPY apps/web/ ./

# 6. Ejecutamos el build (que ya sabemos que da éxito en tu PC local)
RUN pnpm build


# ==========================================
# ETAPA 2: Runtime (nginx para estático)
# ==========================================
FROM nginx:alpine AS runtime

# Crear estructura de directorios correcta
RUN mkdir -p /usr/share/nginx/html

# Copiar archivos estáticos reales generados por @sveltejs/adapter-static
COPY --from=builder /app/apps/web/build /usr/share/nginx/html

# Copiar configuración de nginx
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]