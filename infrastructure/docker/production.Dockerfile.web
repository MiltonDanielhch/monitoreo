# syntax=docker/dockerfile:1

# ==========================================
# Fase 1: Builder (SvelteKit Web Aislado)
# ==========================================
FROM node:22-alpine AS builder
WORKDIR /app

# Activar pnpm v10 idéntico al de tu entorno local
RUN corepack enable && corepack prepare pnpm@10.27.0 --activate

# 1. Copiar manifiestos y dependencias de la web respetando la estructura del monorepo
COPY apps/web/package.json apps/web/pnpm-lock.yaml* ./apps/web/

# 2. Copiar todo el contenido real de la aplicación web
COPY apps/web/ ./apps/web/

# 3. Copiar la carpeta de tipos compartidos (Fundamental si Svelte 5 consume tipos de Rust)
COPY crates/shared_types/ ./crates/shared_types/

# 4. Moverse a la carpeta interna para instalar y compilar
WORKDIR /app/apps/web
RUN pnpm install --frozen-lockfile

# 5. Ejecutar el build estático nativo (Generará la carpeta /app/apps/web/build)
RUN pnpm build

# ==========================================
# Fase 2: Runtime (Nginx Servidor Estático)
# ==========================================
FROM nginx:1.25-alpine AS runtime

# Copiar tu archivo de configuración de Nginx limpio (sin proxies internos)
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf

# Extraer el build limpio hacia el directorio público de Nginx
COPY --from=builder /app/apps/web/build /usr/share/nginx/html

# Nginx escucha en el puerto 80 por defecto
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]